#!/usr/bin/env bash
# Pre-push gate — runs the offline test suite (CI parity: `cargo test
# --all-targets`, .github/workflows/ci.yml) before code leaves the machine.
# Lives here rather than in pre-commit because the full suite is too slow to
# run on every commit; fmt + clippy stay in pre-commit for fast feedback.
#
# Enable once per clone:  git config core.hooksPath .githooks
# Bypass in an emergency: git push --no-verify  (CI still enforces).
#
# Live tests are `#[ignore]` and need docker services, so they stay out of the
# gate — run them explicitly with `cargo test -- --ignored`.
set -euo pipefail

echo "pre-push: cargo test --all-targets (offline)"
cargo test --all-targets --quiet

echo "pre-push: ok"
